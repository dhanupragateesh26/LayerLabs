# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://layerlabs-admin:Dhanu@2006@layerlabs1.nlipnsc.mongodb.net/?appName=layerlabs1

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://layerlabs.vercel.app,https://www.layerlabs.com
ALLOWED_ORIGINS=http://localhost:3000

# Port (optional - hosting platforms set this automatically)
PORT=5000

# Email (Gmail) — for sending order confirmation emails to customers
# EMAIL_USER: your Gmail address
# EMAIL_PASS: Gmail App Password (NOT your regular password)
#   → myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_USER=layerlabs.in@gmail.com
EMAIL_PASS=Dhanu@2006